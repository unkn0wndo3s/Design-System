---
export interface Props {
  type:        'primary' | 'secondary';
  disabled?:   boolean;
  icon?: boolean;
}
const { type, disabled = false, icon = false } = Astro.props;
---

<div class={`button button__${type} ${disabled ? 'button--disabled' : ''} ${icon ? 'button--icon' : ''}`}>
  <slot/>
</div>

<style lang="scss">
@use './_button.scss';
</style>